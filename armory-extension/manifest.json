{
  "manifest_version": 3,
  "name": "Armory Protocol",
  "version": "1.0.0",
  "description": "Verify Solana wallet addresses before you send. The Web3 green tick.",
  
  "permissions": ["activeTab", "scripting", "storage"],
  
  "host_permissions": [
    "https://api.devnet.solana.com/*",
    "https://*/*",
    "http://*/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["armory.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "128": "icons/icon.svg"
  }
}
